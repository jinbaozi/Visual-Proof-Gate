{
  "name": "visual-proof-gate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visual Proof Gate automation between Taste Skill and Impeccable Skill.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run ci",
    "ci": "npm run typecheck && npm run arch:test && npm run vp:unit",
    "arch:test": "playwright test tests/architecture --config=playwright.visual-proof.config.ts",
    "vp:unit": "playwright test tests/visual-proof.unit.spec.ts --config=playwright.visual-proof.config.ts",
    "vp:gate": "playwright test tests/visual-proof.gate.spec.ts --config=playwright.visual-proof.config.ts",
    "vp:middle": "npm run vp:gate",
    "vp:diagnose": "npm run vp:gate",
    "vp:enhance:plan": "npm run vp:gate",
    "vp:handoff": "npm run vp:gate",
    "vp:a11y": "playwright test tests/a11y.spec.ts --config=playwright.visual-proof.config.ts",
    "vp:responsive": "playwright test tests/responsive.spec.ts --config=playwright.visual-proof.config.ts",
    "vp:lhci": "lhci autorun --config=lighthouserc.cjs",
    "vp:all": "npm run typecheck && npm run arch:test && npm run vp:gate && npm run vp:a11y && npm run vp:responsive && npm run vp:lhci"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@lhci/cli": "latest",
    "@playwright/test": "latest",
    "typescript": "latest"
  }
}
